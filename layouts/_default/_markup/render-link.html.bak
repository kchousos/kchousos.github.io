<a href="{{ .Destination | safeURL }}" {{ with .Title}} title="{{ . }}" {{ end }}>
  {{ .Text | safeHTML }}
  {{ if strings.HasPrefix .Destination "http" }}
  <!-- https://commons.wikimedia.org/wiki/File:OOjs_UI_icon_external-link-ltr.svg -->
  <svg version="1.1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px"
    width="16px" height="16x" viewBox="0 0 12 12" style="enable-background:new 0 0 12 12;" xml:space="preserve">
    <g id="Icons">
      <g id="external">
        <polygon fill="currentColor" id="box" style="fill-rule:evenodd;clip-rule:evenodd;"
          points="2,2 5,2 5,3 3,3 3,9 9,9 9,7 10,7 10,10 2,10   " />
        <polygon fill="currentColor" id="arrow_13_" style="fill-rule:evenodd;clip-rule:evenodd;"
          points="6.211,2 10,2 10,5.789 8.579,4.368 6.447,6.5    5.5,5.553 7.632,3.421   " />
      </g>
    </g>
    <g id="Guides" style="display:none;">
    </g>
  </svg>
  {{ end }}
</a>